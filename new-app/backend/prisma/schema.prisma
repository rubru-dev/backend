  id               BigInt                       @id @default(autoincrement())
  column_id        BigInt
  title            String                       @db.VarChar(255)
  description      String?
  lead_id          BigInt?
  assigned_user_id BigInt?
  deadline         DateTime?                    @db.Date
  tanggal_survey   DateTime?                    @db.Date
  color            String?                      @db.VarChar(50)
  urutan           Int                          @default(0)
  created_at       DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime                     @default(now()) @db.Timestamptz(6)
  column           TelemarketingKanbanColumn    @relation(fields: [column_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lead             Lead?                        @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  assigned_user    User?                        @relation(fields: [assigned_user_id], references: [id], onUpdate: NoAction)
  comments         TelemarketingKanbanComment[]
  labels           TelemarketingKanbanLabel[]
  @@index([column_id], map: "idx_telemarketing_kanban_cards_column")
  @@map("telemarketing_kanban_cards")
}

model TelemarketingKanbanComment {
  id         BigInt                  @id @default(autoincrement())
  card_id    BigInt
  user_id    BigInt?
  comment    String
  created_at DateTime                @default(now()) @db.Timestamptz(6)
  updated_at DateTime                @default(now()) @db.Timestamptz(6)
  card       TelemarketingKanbanCard @relation(fields: [card_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User?                   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  @@map("telemarketing_kanban_comments")
}

model TelemarketingKanbanLabel {
  id      BigInt                  @id @default(autoincrement())
  card_id BigInt
  name    String                  @db.VarChar(100)
  color   String?                 @db.VarChar(50)
  card    TelemarketingKanbanCard @relation(fields: [card_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("telemarketing_kanban_labels")
}
