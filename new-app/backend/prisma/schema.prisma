  @@map("design_reports")
}

model FinanceReport {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt?
  bulan      Int?
  tahun      Int?
  data       Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      User?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  @@map("finance_reports")
}

model FollowUpClient {
  id             BigInt    @id @default(autoincrement())
  lead_id        BigInt
  user_id        BigInt?
  tanggal        DateTime? @db.Date
  catatan        String?
  next_follow_up DateTime? @db.Date
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  lead          Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user          User?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  @@map("follow_up_clients")
}

model GajiTukangItem {
  id              BigInt          @id @default(autoincrement())
  gaji_tukang_id  BigInt
  tukang_id       BigInt?
  tukang_name     String?         @db.VarChar(255)
  hari_kerja      Int             @default(0)
  daily_rate      Decimal         @default(0) @db.Decimal(15, 2)
  kasbon_dipotong Decimal         @default(0) @db.Decimal(15, 2)
  subtotal        Decimal         @default(0) @db.Decimal(15, 2)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  gaji_tukang     GajiTukang      @relation(fields: [gaji_tukang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tukang_reg      TukangRegistry? @relation(fields: [tukang_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  @@map("gaji_tukang_items")
}

model GajiTukang {
  id                     BigInt                  @id @default(autoincrement())
