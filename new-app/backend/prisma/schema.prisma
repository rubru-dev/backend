generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AbsenTukangItem {
  id              BigInt        @id @default(autoincrement())
  absen_tukang_id BigInt
  tukang_name     String?       @db.VarChar(255)
  hadir           Boolean       @default(true)
  keterangan      String?       @db.VarChar(255)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  absen_tukang   AbsenTukang @relation(fields: [absen_tukang_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("absen_tukang_items")
}

model AbsenTukang {
  id                     BigInt                @id @default(autoincrement())
  adm_finance_project_id BigInt?
  tanggal                DateTime?             @db.Date
  keterangan             String?
  created_by             BigInt?
  created_at             DateTime              @default(now()) @db.Timestamptz(6)
  updated_at             DateTime              @default(now()) @db.Timestamptz(6)
  items     AbsenTukangItem[]
  adm_finance_project   AdmFinanceProject? @relation(fields: [adm_finance_project_id], references: [id], onUpdate: NoAction)
  creator                  User?                @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  @@map("absen_tukangs")
}

model ActivityLog {
  id           BigInt   @id @default(autoincrement())
  log_name     String?  @db.VarChar(255)
  description  String
  subject_type String?  @db.VarChar(255)
  subject_id   BigInt?
  causer_type  String?  @db.VarChar(255)
  causer_id    BigInt?
  properties   Json?
  event        String?  @db.VarChar(255)
  batch_uuid   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([causer_type, causer_id], map: "idx_activity_log_causer")
  @@index([event], map: "idx_activity_log_event")
  @@index([subject_type, subject_id], map: "idx_activity_log_subject")
  @@map("activity_log")
}

model AdContentMetric {
  id                   BigInt             @id @default(autoincrement())
  meta_ads_campaign_id BigInt
  date                 DateTime           @db.Date
  impressions          BigInt             @default(0)
  reach                BigInt             @default(0)
  clicks               Int                @default(0)
  ctr                  Decimal            @default(0) @db.Decimal(10, 4)
  spend                Decimal            @default(0) @db.Decimal(15, 2)
  likes                Int                @default(0)
  comments             Int                @default(0)
  shares               Int                @default(0)
  video_views          Int                @default(0)
  engagement_rate      Decimal            @default(0) @db.Decimal(10, 4)
  cost_per_result      Decimal            @default(0) @db.Decimal(15, 2)
  roas                 Decimal            @default(0) @db.Decimal(10, 4)
  frequency            Decimal            @default(0) @db.Decimal(10, 4)
  conversions          Int                @default(0)
  data_source          String             @default("manual") @db.VarChar(50)
  created_at           DateTime           @default(now()) @db.Timestamptz(6)
  updated_at           DateTime           @default(now()) @db.Timestamptz(6)
  meta_ads_campaigns   MetaAdsCampaign @relation(fields: [meta_ads_campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([meta_ads_campaign_id, date])
  @@index([meta_ads_campaign_id], map: "idx_ad_content_metrics_campaign")
  @@index([date], map: "idx_ad_content_metrics_date")
  @@map("ad_content_metrics")
}

model AdmFinanceItem {
  id                   BigInt               @id @default(autoincrement())
  periode_id           BigInt
  description          String?
  qty                  Decimal              @default(1) @db.Decimal(15, 3)
  unit_price           Decimal              @default(0) @db.Decimal(15, 2)
  total                Decimal              @default(0) @db.Decimal(15, 2)
  status               String               @default("aktif") @db.VarChar(50)
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  periode AdmFinancePeriode @relation(fields: [periode_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([periode_id], map: "idx_adm_finance_items_periode")
  @@map("adm_finance_items")
}

model AdmFinancePeriode {
  id                       BigInt              @id @default(autoincrement())
  termin_id                BigInt
  nama_periode             String?             @db.VarChar(255)
  tanggal_mulai            DateTime?           @db.Date
  tanggal_selesai          DateTime?           @db.Date
  budget                   Decimal             @default(0) @db.Decimal(15, 2)
  is_approved              Boolean             @default(false)
  approved_by              BigInt?
  approved_at              DateTime?           @db.Timestamptz(6)
  budget_warning_threshold Decimal?            @db.Decimal(15, 2)
  budget_warning_sent      Boolean             @default(false)
  status                   String              @default("aktif") @db.VarChar(50)
  created_at               DateTime            @default(now()) @db.Timestamptz(6)
  updated_at               DateTime            @default(now()) @db.Timestamptz(6)
  items        AdmFinanceItem[]
  approver                    User?              @relation(fields: [approved_by], references: [id], onUpdate: NoAction)
  termin      AdmFinanceTermin @relation(fields: [termin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([termin_id], map: "idx_adm_finance_periodes_termin")
  @@map("adm_finance_periodes")
}

model AdmFinanceProject {
  id                    BigInt                @id @default(autoincrement())
  nama_proyek           String?               @db.VarChar(255)
  klien                 String?               @db.VarChar(255)
  jenis                 String?               @db.VarChar(50)
  lead_id               BigInt?
  proyek_berjalan_id    BigInt?
  lokasi                String?
  tanggal_mulai         DateTime?             @db.Date
  tanggal_selesai       DateTime?             @db.Date
  jumlah_termin         Int                   @default(0)
  status                String                @default("aktif") @db.VarChar(50)
  created_by            BigInt?
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @db.Timestamptz(6)
  absen_tukangs         AbsenTukang[]
  cashflows             ProjekCashflow[]
  list_materials        ProjekListMaterial[]
  purchase_requests     ProjekPR[]
  dokumens              ProjekDokumen[]
  creator               User?                 @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  lead                  Lead?                 @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  proyek_berjalan       ProyekBerjalan?       @relation(fields: [proyek_berjalan_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  termins               AdmFinanceTermin[]
  gaji_tukangs          GajiTukang[]
  surat_jalans          SuratJalan[]
  tukang_registries     TukangRegistry[]
  @@map("adm_finance_projects")
}

model AdmFinanceTermin {
  id                   BigInt                 @id @default(autoincrement())
  project_id           BigInt
  nama_termin          String                 @db.VarChar(255)
  tanggal              DateTime?              @db.Date
  budget               Decimal                @default(0) @db.Decimal(15, 2)
  deposit_awal         Decimal                @default(0) @db.Decimal(15, 2)
  hf_signed_at         DateTime?              @db.Timestamptz(6)
  hf_signed_by         BigInt?
  hf_name              String?                @db.VarChar(255)
  hf_signature         String?                @db.Text
  status               String                 @default("aktif") @db.VarChar(50)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  periodes             AdmFinancePeriode[]
  deposits             ProjekTerminDeposit[]
  cashflow_items       ProjekCashflow[]
  project              AdmFinanceProject      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("adm_finance_termins")
}

model ProjekTerminDeposit {
  id           BigInt           @id @default(autoincrement())
  termin_id    BigInt
  jumlah       Decimal          @default(0) @db.Decimal(15, 2)
  catatan      String?
  hf_signed_at DateTime?        @db.Timestamptz(6)
  hf_signed_by BigInt?
  hf_name      String?          @db.VarChar(255)
  hf_signature String?          @db.Text
  created_at   DateTime         @default(now()) @db.Timestamptz(6)
  updated_at   DateTime         @default(now()) @db.Timestamptz(6)
  termin       AdmFinanceTermin @relation(fields: [termin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("projek_termin_deposits")
}

model AdministrasiKantorItem {
  id                     BigInt               @id @default(autoincrement())
  administrasi_kantor_id BigInt
  description            String?
  qty                    Decimal              @default(1) @db.Decimal(15, 3)
  amount                 Decimal              @default(0) @db.Decimal(15, 2)
  created_at             DateTime             @default(now()) @db.Timestamptz(6)
  updated_at             DateTime             @default(now()) @db.Timestamptz(6)
  administrasi_kantor   AdministrasiKantor @relation(fields: [administrasi_kantor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("administrasi_kantor_items")
}

model AdministrasiKantor {
  id                        BigInt                      @id @default(autoincrement())
  lead_id                   BigInt?
  tanggal                   DateTime?                   @db.Date
  keterangan                String?
  created_by                BigInt?
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                    @default(now()) @db.Timestamptz(6)
  items AdministrasiKantorItem[]
  creator                     User?                      @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  lead                     Lead?                      @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  @@map("administrasi_kantors")
}

model Reimburse {
  id                      BigInt           @id @default(autoincrement())
  tanggal                 DateTime?        @db.Date
  user_id                 BigInt?
  kategori                String?          @db.VarChar(100)
  keterangan              String?
  total                   Decimal          @default(0) @db.Decimal(15, 2)
  status                  String           @default("Pending") @db.VarChar(50)
  alasan_tolak            String?
  head_finance_id         BigInt?
  head_finance_at         DateTime?        @db.Timestamptz(6)
  head_finance_signature  String?          @db.Text
  admin_finance_id        BigInt?
  admin_finance_at        DateTime?        @db.Timestamptz(6)
  admin_finance_signature String?          @db.Text
  created_by              BigInt?
  created_at              DateTime         @default(now()) @db.Timestamptz(6)
  updated_at              DateTime         @default(now()) @db.Timestamptz(6)
  user          User?           @relation("reimburse_karyawan", fields: [user_id], references: [id], onUpdate: NoAction)
  head_finance  User?           @relation("reimburse_head_finance", fields: [head_finance_id], references: [id], onUpdate: NoAction)
  admin_finance User?           @relation("reimburse_admin_finance", fields: [admin_finance_id], references: [id], onUpdate: NoAction)
  creator       User?           @relation("reimburse_creator", fields: [created_by], references: [id], onUpdate: NoAction)
  items         ReimburseItem[]
  buktis        ReimburseBukti[]
  @@map("reimburses")
}

model ReimburseItem {
  id           BigInt    @id @default(autoincrement())
  reimburse_id BigInt
  deskripsi    String?
  jumlah       Decimal   @default(0) @db.Decimal(15, 2)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  reimburse    Reimburse @relation(fields: [reimburse_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("reimburse_items")
}

model ReimburseBukti {
  id           BigInt    @id @default(autoincrement())
  reimburse_id BigInt
  data         String    @db.Text
  nama         String?   @db.VarChar(255)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  reimburse    Reimburse @relation(fields: [reimburse_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("reimburse_buktis")
}

model AlembicVersion {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
  @@map("alembic_version")
}

model AppSetting {
  id         BigInt   @id @default(autoincrement())
  key        String   @unique @db.VarChar(255)
  value      Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  @@map("app_settings")
}

model BarangTermin {
  id                BigInt           @id @default(autoincrement())
  termin_id         BigInt
  warehouse_id      BigInt?
  stok_warehouse_id BigInt?
  barang_id         BigInt?
  quantity          Decimal          @default(0) @db.Decimal(15, 3)
  jumlah_sisa       Decimal          @default(0) @db.Decimal(15, 3)
  price             Decimal          @default(0) @db.Decimal(15, 2)
  total_harga       Decimal          @default(0) @db.Decimal(15, 2)
  supplier          String?          @db.VarChar(255)
  satuan            String?          @db.VarChar(50)
  status            String?          @db.VarChar(50)
  tanggal_pemakaian DateTime?        @db.Date
  keterangan        String?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime         @default(now()) @db.Timestamptz(6)
  barang           Barang?         @relation(fields: [barang_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stok_warehouse   StokWarehouse? @relation(fields: [stok_warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  termin           Termin          @relation(fields: [termin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouse        Warehouse?      @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tanggal_pemakaian], map: "idx_barang_termins_tanggal")
  @@index([termin_id], map: "idx_barang_termins_termin")
  @@map("barang_termins")
}

model Barang {
  id                      BigInt                    @id @default(autoincrement())
  kategori_id             BigInt?
  nama                    String                    @db.VarChar(255)
  supplier                String?                   @db.VarChar(255)
  price                   Decimal                   @default(0) @db.Decimal(15, 2)
  satuan                  String?                   @db.VarChar(50)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  barang_termins          BarangTermin[]
  kategori        KategoriBarang?         @relation(fields: [kategori_id], references: [id], onUpdate: NoAction)
  stock_opname_rapp_items StockOpnameRappItem[]
  stok_warehouses         StokWarehouse[]
  surat_jalan_items       SuratJalanItem[]
  transfer_items          TransferItem[]
  @@map("barangs")
}

model BdReport {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt?
  bulan      Int?
  tahun      Int?
  data       Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      User?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  @@map("bd_reports")
}

model BonHarianFile {
  id            BigInt      @id @default(autoincrement())
  bon_harian_id BigInt
  file_path     String?     @db.VarChar(500)
  original_name String?     @db.VarChar(255)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @db.Timestamptz(6)
  bon_harian   BonHarian @relation(fields: [bon_harian_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("bon_harian_files")
}

model BonHarian {
  id               BigInt             @id @default(autoincrement())
  projek_id        BigInt
  tanggal          DateTime?          @db.Date
  penerima         String?            @db.VarChar(255)
  keterangan       String?
  created_by       BigInt?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  files BonHarianFile[]
  creator            User?             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projek          Projek            @relation(fields: [projek_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  @@map("bon_harians")
}

model ContentCreatorReport {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt?
  bulan      Int?
  tahun      Int?
  data       Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      User?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  @@map("content_creator_reports")
}

model ContentTimeline {
  id              BigInt    @id @default(autoincrement())
  user_id         BigInt?
  title           String?   @db.VarChar(255)
  content_type    String?   @db.VarChar(100)
  deadline        DateTime? @db.Date
  approval_status String    @default("pending") @db.VarChar(50)
  produksi_status String?   @db.VarChar(50)
  bulan           Int?
  tahun           Int?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
  judul           String?   @db.VarChar(255)
  deskripsi       String?
  platform        String?   @db.VarChar(100)
  tanggal_publish DateTime? @db.Date
  tanggal_upload  DateTime? @db.Date
  status          String?   @default("Draft") @db.VarChar(50)
  file_path       String?   @db.VarChar(500)
  planning_status String?   @default("pending") @db.VarChar(50)
  upload_status   String?   @db.VarChar(50)
  catatan_revisi    String?
  hd_bd_signature   String?   @db.Text
  hd_bd_signed_at   DateTime? @db.Timestamptz(6)
  task_image        String?   @db.Text
  user           User?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  @@map("content_timelines")
}

model InteriorTimeline {
  id              BigInt                 @id @default(autoincrement())
  nama_proyek     String?                @db.VarChar(200)
  lead_id         BigInt?
  tanggal_mulai   DateTime?              @db.Date
  tanggal_selesai DateTime?              @db.Date
  created_by      BigInt?
  created_at      DateTime               @default(now()) @db.Timestamptz(6)
  updated_at      DateTime               @default(now()) @db.Timestamptz(6)
  items           InteriorTimelineItem[]
  creator         User?                  @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  lead            Lead?                  @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  @@map("interior_timelines")
}

model InteriorTimelineItem {
  id                    BigInt            @id @default(autoincrement())
  interior_timeline_id  BigInt
  item_pekerjaan        String?
  pic                   BigInt?
  status                String?           @db.VarChar(50)
  tanggal_mulai         DateTime?         @db.Date
  target_selesai        DateTime?         @db.Date
  file_bukti            String?           @db.VarChar(500)
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime          @default(now()) @db.Timestamptz(6)
  interior_timeline     InteriorTimeline  @relation(fields: [interior_timeline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                  User?             @relation(fields: [pic], references: [id], onUpdate: NoAction)
  @@map("interior_timeline_items")
}

model DesainTimelineItem {
  id                 BigInt           @id @default(autoincrement())
  desain_timeline_id BigInt
  item_pekerjaan     String?
  pic                BigInt?
  status             String?          @db.VarChar(50)
  tanggal_mulai      DateTime?        @db.Date
  target_selesai     DateTime?        @db.Date
  file_bukti         String?          @db.VarChar(500)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @default(now()) @db.Timestamptz(6)
  desain_timeline   DesainTimeline @relation(fields: [desain_timeline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user              User?           @relation(fields: [pic], references: [id], onUpdate: NoAction)
  @@map("desain_timeline_items")
}

model DesainTimeline {
  id                    BigInt                  @id @default(autoincrement())
  lead_id               BigInt?
  jenis_desain          String?                 @db.VarChar(100)
  bulan                 Int?
  tahun                 Int?
  tanggal_mulai         DateTime?               @db.Date
  tanggal_selesai       DateTime?               @db.Date
  created_by            BigInt?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  items DesainTimelineItem[]
  creator                 User?                  @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  lead                 Lead?                  @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  @@map("desain_timelines")
}

model DesignReport {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt?
  bulan      Int?
  tahun      Int?
  data       Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
