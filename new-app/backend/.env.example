# Backend .env — copy to .env and fill values

APP_NAME="StockOpname API"
DEBUG=true
PORT=8000

# JWT
SECRET_KEY=your_jwt_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://stockopname:secret@localhost:5432/stockopname

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_ALL=false

# Storage
STORAGE_PATH=storage

# WhatsApp (Fonnte)
FONNTE_TOKEN=
FONNTE_API_URL=https://api.fonnte.com/send

# Meta Ads
META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=
META_ADS_API_VERSION=v21.0

# App URLs
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
