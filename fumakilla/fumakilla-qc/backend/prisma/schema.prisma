generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALES)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquiries         Inquiry[]
  quotations        Quotation[]          @relation("QuotationOwner")
  surveys           Survey[]             @relation("SurveyPic")
  surveyAssignments SurveyPicAssignment[] @relation("SurveyPicAssignments")
  reports           DailyReport[]
  activities        ActivityLog[]
}

enum Role {
  ADMIN
  SALES
  SURVEYOR
  MANAGER
  QA
}
enum InquiryStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}
enum RenewalStatus {
  UPCOMING
  IN_PROGRESS
  RENEWED
  EXPIRED
}
enum SurveyStatus {
  SCHEDULED
  COMPLETED
  POSTPONED
  CANCELLED
}
enum AfterSurveyStatus {
  PENDING
  REVIEW
  DONE
}
enum ServiceContractStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}
enum WorkStatus {
  PENDING
  COMPLETED
}

model Customer {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  company   String?
  phone     String?
  email     String?
  address   String?
  city      String?
  treatmentAddress String?
  status    String   @default("Non-Kontrak")
  segment   String?
  segmentType String?
  vendorName String?
  dppVendor String?
  dppFi String?
  agreementDurationMonths Int?
  customerType String?
  treatment String?
  treatmentFrequency String?
  treatmentDuration String?
  treatmentTime String?
  serviceArea String?
  agreementType String?
  agreementNumber String?
  agreementStart DateTime?
  agreementEnd DateTime?
  agreementValue Decimal? @db.Decimal(15, 2)
  ownerName String?
  salesOwner String?
  leadSource String?
  picServiceName String?
  picServicePhone String?
  picServiceEmail String?
  picScheduleName String?
  picSchedulePhone String?
  picScheduleEmail String?
  billingName String?
  billingPhone String?
  billingEmail String?
  billingAddress String?
  npwpNumber String?
  npwpName String?
  responsibleOwnerKtp String?
  npwpAddress String?
  monthlyReportFrequency String?
  qcName String?
  qaName String?
  agreementPicName String?
  agreementPicTitle String?
  invoicePicName String?
  invoicePicPhone String?
  invoicePicEmail String?
  invoicePicAddress String?
  invoiceAcceptanceLimitDays Int?
  paymentMethod String?
  paymentTerms Int?
  notes     String?  @db.Text
  isPriority Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquiries  Inquiry[]
  quotations Quotation[]
  renewals   Renewal[]
  surveys    Survey[]
  files      CustomerFile[]
  invoices   OutstandingInvoice[]
  serviceContracts ServiceContract[]
}

model CustomerFile {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  category    String   @default("OTHER")
  description String?
  filePath    String
  mimeType    String
  size        Int
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  service     String
  source      String?
  inquiryDate DateTime      @default(now())
  contactMonth String        @default("")
  progress    String        @default("New Inquiry")
  result      String        @default("On Going")
  picFiId     String?
  picFiName   String        @default("")
  segmentType String        @default("B2C")
  areaSizeM2  Decimal?      @db.Decimal(12, 2)
  serviceType String        @default("")
  customerCity String       @default("")
  closingDate DateTime?
  closingMonth String       @default("")
  customerName String        @default("")
  companyName String         @default("")
  picName     String         @default("")
  phone       String         @default("")
  email       String?
  address     String          @default("") @db.Text
  buildingType String         @default("")
  salesPic    String          @default("")
  status      InquiryStatus @default(NEW)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ownerId     String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner    User     @relation(fields: [ownerId], references: [id])
  quotations Quotation[]
  surveys    Survey[]
}

model Quotation {
  id          String          @id @default(cuid())
  number      String          @unique
  customerId  String
  inquiryId   String?
  title       String
  amount      Decimal         @db.Decimal(15, 2)
  status      QuotationStatus @default(DRAFT)
  validUntil  DateTime?
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  ownerId     String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  inquiry  Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  owner    User     @relation("QuotationOwner", fields: [ownerId], references: [id])
}

model Renewal {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  service     String
  expiryDate  DateTime
  status      RenewalStatus @default(UPCOMING)
  progress    Int           @default(0)
  notes       String?       @db.Text
  notificationStatus WorkStatus @default(PENDING)
  draftAgreementStatus WorkStatus @default(PENDING)
  draftOrderSheetStatus WorkStatus @default(PENDING)
  agreementSignedStatus WorkStatus @default(PENDING)
  finalizeOrderSheetStatus WorkStatus @default(PENDING)
  sentToVendorStatus WorkStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Survey {
  id          String       @id @default(cuid())
  number      String       @unique
  customerId  String
  inquiryId   String?
  picId       String
  scheduledAt DateTime
  location    String
  shareLocationUrl String?
  evidenceImagePath String?
  evidenceCapturedAt DateTime?
  evidenceLatitude Float?
  evidenceLongitude Float?
  evidenceAccuracy Float?
  checkoutImagePath String?
  checkoutCapturedAt DateTime?
  checkoutLatitude Float?
  checkoutLongitude Float?
  checkoutAccuracy Float?
  b2cFloorDescriptions Json?
  b2cIssues Json?
  b2cPestFindings Json?
  b2cUnitName String?
  b2cQuantity Int?
  b2cTreatments String[] @default([])
  b2cVisitQty Int?
  b2cVisitPerMonth Int?
  b2cTotalCost Decimal? @db.Decimal(15, 2)
  b2cVendorName String?
  b2cExistingPestControl String? @db.Text
  b2cPointNotes String[] @default([])
  status      SurveyStatus @default(SCHEDULED)
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer       Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  inquiry        Inquiry?              @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  pic            User                  @relation("SurveyPic", fields: [picId], references: [id])
  picAssignments SurveyPicAssignment[]
  afterSurvey    AfterSurvey?
  b2bReport      B2BSurveyReport?
}

model SurveyPicAssignment {
  surveyId String
  picId    String
  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  pic      User   @relation("SurveyPicAssignments", fields: [picId], references: [id])

  @@id([surveyId, picId])
}

model AfterSurvey {
  id        String            @id @default(cuid())
  surveyId  String            @unique
  status    AfterSurveyStatus @default(PENDING)
  reportDue DateTime?
  reportUrl String?
  findings String? @db.Text
  recommendation String? @db.Text
  nextAction String? @db.Text
  submittedAt DateTime?
  reviewedAt DateTime?
  reviewedByName String?
  qcNotes String? @db.Text
  fieldFindings Json?
  pestFindings Json?
  treatmentRecommendations String[] @default([])
  materials String[] @default([])
  surveyedAreas Json?
  authorizedByName String?
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model B2BSurveyReport {
  id        String   @id @default(cuid())
  surveyId  String   @unique

  // Page 1 - Cover
  clientName    String @default("")
  clientAddress String @default("") @db.Text

  // Page 2 - Survey Info
  surveyorNames String @default("")
  surveyDate    String @default("")
  generalNotes  Json   @default("[]")

  // Page 3 - Environment Fact
  topViewImagePath   String?
  frontViewImagePath String?
  mapImagePath       String?
  canvasDataEnv      Json?
  areaCondition      String @default("") @db.Text
  environmentalRisks Json   @default("[]")

  // Page 4 - Pest Concern
  pestConcernImagePath String?
  canvasDataPest       Json?
  pestConcern          String @default("") @db.Text
  inspectionFocus      String @default("") @db.Text

  // Page 5 - Risk Mapping / Floor Plan
  floorPlanImagePath  String?
  floorPlanCanvasData Json?

  // Pages 6-17: Pest Sections [{id,pestType,title,findings[],pestFact[],canvasData,photos:[{path,caption,markerNumber}]}]
  pestSections Json @default("[]")

  // Page 18 - Resume [{pestType,summary,recommendation}]
  resumeRows Json @default("[]")

  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id             String   @id @default(cuid())
  reportDate     DateTime @unique @db.Date
  inquiryCount   Int      @default(0)
  quotationCount Int      @default(0)
  surveyCount    Int      @default(0)
  productivity   Int      @default(0)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  authorId       String

  author User @relation(fields: [authorId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model OutstandingInvoice {
  id          String   @id @default(cuid())
  customerId  String
  number      String   @unique
  description String?
  amount      Decimal  @db.Decimal(15, 2)
  dueDate     DateTime
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model RolePermission {
  role        Role     @id
  permissions String[]
  updatedAt   DateTime @updatedAt
}

model ReminderSetting {
  key             String   @id
  enabled         Boolean  @default(false)
  config          Json?
  secretEncrypted String?
  updatedAt       DateTime @updatedAt
}

model ServiceContract {
  id        String                @id @default(cuid())
  customerId String
  number    String                @unique
  service   String
  startDate DateTime
  endDate   DateTime
  status    ServiceContractStatus @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  monthlyReports    MonthlyReport[]
  qcVisits          QcVisit[]
  vendorTreatments  VendorTreatment[]
}

model MonthlyReport {
  id         String          @id @default(cuid())
  contractId String
  reportDate DateTime
  status     WorkStatus      @default(PENDING)
  notes      String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  contract   ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model QcVisit {
  id          String          @id @default(cuid())
  contractId  String
  scheduledAt DateTime
  status      WorkStatus      @default(PENDING)
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  contract    ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model VendorTreatment {
  id          String          @id @default(cuid())
  contractId  String
  vendorName  String
  scheduledAt DateTime
  status      WorkStatus      @default(PENDING)
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  contract    ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}
