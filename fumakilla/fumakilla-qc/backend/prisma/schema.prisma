generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALES)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquiries         Inquiry[]
  quotations        Quotation[]          @relation("QuotationOwner")
  surveys           Survey[]             @relation("SurveyPic")
  surveyAssignments SurveyPicAssignment[] @relation("SurveyPicAssignments")
  reports           DailyReport[]
  activities        ActivityLog[]
  ownedWorkPlans    WorkPlan[]            @relation("WorkPlanOwner")
  createdWorkPlans  WorkPlan[]            @relation("WorkPlanCreator")
  taggedWorkPlans   WorkPlanTaggedUser[]  @relation("WorkPlanTaggedUsers")
  workPlanCheckpoints WorkPlanCheckpoint[] @relation("WorkPlanCheckpointUser")
  workPlanLogs      WorkPlanAuditLog[]    @relation("WorkPlanAuditActor")
}

enum Role {
  ADMIN
  SALES
  SURVEYOR
  MANAGER
  QA
}
enum InquiryStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}
enum RenewalStatus {
  UPCOMING
  IN_PROGRESS
  RENEWED
  EXPIRED
}
enum SurveyStatus {
  SCHEDULED
  COMPLETED
  POSTPONED
  CANCELLED
}
enum AfterSurveyStatus {
  PENDING
  REVIEW
  DONE
}
enum ServiceContractStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}
enum WorkStatus {
  PENDING
  COMPLETED
}
enum WorkPlanStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum WorkPlanCheckpointType {
  CHECK_IN
  CHECK_OUT
}
enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}
enum OrderSheetStatus {
  DRAFT
  FINAL
  SENT
  COMPLETED
  CANCELLED
}
enum ComplaintSource {
  CUSTOMER
  INTERNAL
  VENDOR
}
enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  WAITING_VENDOR
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
  CANCELLED
}
enum ComplaintPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
enum AgreementStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  CANCELLED
}

model Customer {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  company   String?
  phone     String?
  email     String?
  address   String?
  city      String?
  treatmentAddress String?
  status    String   @default("Non-Kontrak")
  segment   String?
  segmentType String?
  vendorName String?
  dppVendor String?
  dppFi String?
  agreementDurationMonths Int?
  customerType String?
  treatment String?
  treatmentFrequency String?
  treatmentDuration String?
  treatmentTime String?
  serviceArea String?
  agreementType String?
  agreementNumber String?
  agreementStart DateTime?
  agreementEnd DateTime?
  agreementValue Decimal? @db.Decimal(15, 2)
  ownerName String?
  salesOwner String?
  leadSource String?
  picServiceName String?
  picServicePhone String?
  picServiceEmail String?
  picScheduleName String?
  picSchedulePhone String?
  picScheduleEmail String?
  billingName String?
  billingPhone String?
  billingEmail String?
  billingAddress String?
  npwpNumber String?
  npwpName String?
  responsibleOwnerKtp String?
  npwpAddress String?
  monthlyReportFrequency String?
  qcName String?
  qaName String?
  agreementPicName String?
  agreementPicTitle String?
  invoicePicName String?
  invoicePicPhone String?
  invoicePicEmail String?
  invoicePicAddress String?
  invoiceAcceptanceLimitDays Int?
  paymentMethod String?
  paymentTerms Int?
  notes     String?  @db.Text
  isPriority Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquiries  Inquiry[]
  quotations Quotation[]
  renewals   Renewal[]
  surveys    Survey[]
  files      CustomerFile[]
  invoices   OutstandingInvoice[]
  serviceContracts ServiceContract[]
  orderSheets OrderSheet[]
  complaints      Complaint[]
  agreementReports AgreementReport[]
  agreements      Agreement[]
}

model CustomerFile {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  category    String   @default("OTHER")
  description String?
  filePath    String
  mimeType    String
  size        Int
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  service     String
  source      String?
  inquiryDate DateTime      @default(now())
  contactMonth String        @default("")
  progress    String        @default("New Inquiry")
  result      String        @default("On Going")
  picFiId     String?
  picFiName   String        @default("")
  segmentType String        @default("B2C")
  areaSizeM2  Decimal?      @db.Decimal(12, 2)
  serviceType String        @default("")
  customerCity String       @default("")
  closingDate DateTime?
  closingMonth String       @default("")
  customerName String        @default("")
  companyName String         @default("")
  picName     String         @default("")
  phone       String         @default("")
  email       String?
  address     String          @default("") @db.Text
  buildingType String         @default("")
  salesPic    String          @default("")
  status      InquiryStatus @default(NEW)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ownerId     String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner    User     @relation(fields: [ownerId], references: [id])
  quotations  Quotation[]
  surveys     Survey[]
  pestReports PestMonthlyReport[]
}

model Quotation {
  id            String          @id @default(cuid())
  number        String          @unique
  customerId    String
  inquiryId     String?
  title         String
  amount        Decimal         @db.Decimal(15, 2)
  status        QuotationStatus @default(DRAFT)
  validUntil    DateTime?
  notes         String?         @db.Text
  quotationDate DateTime        @default(now())
  segmentType   String          @default("B2B")
  hasilSurvey   Json            @default("[]")
  priceData     Json            @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  ownerId       String

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  inquiry    Inquiry?    @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  owner      User        @relation("QuotationOwner", fields: [ownerId], references: [id])
  agreements Agreement[]
}

model Renewal {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  service     String
  expiryDate  DateTime
  status      RenewalStatus @default(UPCOMING)
  progress    Int           @default(0)
  notes       String?       @db.Text
  notificationStatus WorkStatus @default(PENDING)
  draftAgreementStatus WorkStatus @default(PENDING)
  draftOrderSheetStatus WorkStatus @default(PENDING)
  agreementSignedStatus WorkStatus @default(PENDING)
  finalizeOrderSheetStatus WorkStatus @default(PENDING)
  sentToVendorStatus WorkStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Survey {
  id          String       @id @default(cuid())
  number      String       @unique
  customerId  String
  inquiryId   String?
  picId       String
  scheduledAt DateTime
  location    String
  shareLocationUrl String?
  evidenceImagePath String?
  evidenceCapturedAt DateTime?
  evidenceLatitude Float?
  evidenceLongitude Float?
  evidenceAccuracy Float?
  checkoutImagePath String?
  checkoutCapturedAt DateTime?
  checkoutLatitude Float?
  checkoutLongitude Float?
  checkoutAccuracy Float?
  b2cFloorDescriptions Json?
  b2cIssues Json?
  b2cPestFindings Json?
  b2cUnitName String?
  b2cQuantity Int?
  b2cTreatments String[] @default([])
  b2cVisitQty Int?
  b2cVisitPerMonth Int?
  b2cTotalCost Decimal? @db.Decimal(15, 2)
  b2cVendorName String?
  b2cExistingPestControl String? @db.Text
  b2cPointNotes String[] @default([])
  b2cReportData Json?
  status      SurveyStatus @default(SCHEDULED)
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer       Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  inquiry        Inquiry?              @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  pic            User                  @relation("SurveyPic", fields: [picId], references: [id])
  picAssignments SurveyPicAssignment[]
  afterSurvey    AfterSurvey?
  b2bReport      B2BSurveyReport?
}

model SurveyPicAssignment {
  surveyId String
  picId    String
  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  pic      User   @relation("SurveyPicAssignments", fields: [picId], references: [id])

  @@id([surveyId, picId])
}

model AfterSurvey {
  id        String            @id @default(cuid())
  surveyId  String            @unique
  status    AfterSurveyStatus @default(PENDING)
  reportDue DateTime?
  reportUrl String?
  findings String? @db.Text
  recommendation String? @db.Text
  nextAction String? @db.Text
  submittedAt DateTime?
  reviewedAt DateTime?
  reviewedByName String?
  qcNotes String? @db.Text
  fieldFindings Json?
  pestFindings Json?
  treatmentRecommendations String[] @default([])
  materials String[] @default([])
  surveyedAreas Json?
  authorizedByName String?
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model B2BSurveyReport {
  id        String   @id @default(cuid())
  surveyId  String   @unique

  // Page 1 - Cover
  clientName    String @default("")
  clientAddress String @default("") @db.Text

  // Page 2 - Survey Info
  surveyorNames String @default("")
  surveyDate    String @default("")
  generalNotes  Json   @default("[]")

  // Page 3 - Environment Fact
  topViewImagePath   String?
  frontViewImagePath String?
  mapImagePath       String?
  canvasDataEnv      Json?
  areaCondition      String @default("") @db.Text
  environmentalRisks Json   @default("[]")

  // Page 4 - Pest Concern
  pestConcernImagePath String?
  canvasDataPest       Json?
  pestConcern          String @default("") @db.Text
  inspectionFocus      String @default("") @db.Text

  // Page 5 - Risk Mapping / Floor Plan
  floorPlanImagePath  String?
  floorPlanCanvasData Json?

  // Pages 6-17: Pest Sections [{id,pestType,title,findings[],pestFact[],canvasData,photos:[{path,caption,markerNumber}]}]
  pestSections Json @default("[]")

  // Page 18 - Resume [{pestType,summary,recommendation}]
  resumeRows Json @default("[]")

  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id             String   @id @default(cuid())
  reportDate     DateTime @unique @db.Date
  inquiryCount   Int      @default(0)
  quotationCount Int      @default(0)
  surveyCount    Int      @default(0)
  productivity   Int      @default(0)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  authorId       String

  author User @relation(fields: [authorId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WorkPlan {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  workDate    DateTime       @db.Date
  startTime   String
  endTime     String?
  location    String?
  status      WorkPlanStatus @default(PLANNED)
  ownerId     String
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner       User                 @relation("WorkPlanOwner", fields: [ownerId], references: [id])
  createdBy   User                 @relation("WorkPlanCreator", fields: [createdById], references: [id])
  taggedUsers WorkPlanTaggedUser[]
  checkpoints WorkPlanCheckpoint[]
  logs        WorkPlanAuditLog[]

  @@index([workDate])
  @@index([ownerId])
  @@index([status])
}

model WorkPlanTaggedUser {
  workPlanId String
  userId     String
  createdAt  DateTime @default(now())

  workPlan WorkPlan @relation(fields: [workPlanId], references: [id], onDelete: Cascade)
  user     User     @relation("WorkPlanTaggedUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([workPlanId, userId])
}

model WorkPlanCheckpoint {
  id          String                 @id @default(cuid())
  workPlanId  String
  userId      String
  type        WorkPlanCheckpointType
  note        String?                @db.Text
  filePath    String?
  fileName    String?
  mimeType    String?
  size        Int?
  latitude    Float?
  longitude   Float?
  accuracy    Float?
  createdAt   DateTime               @default(now())

  workPlan WorkPlan @relation(fields: [workPlanId], references: [id], onDelete: Cascade)
  user     User     @relation("WorkPlanCheckpointUser", fields: [userId], references: [id])

  @@unique([workPlanId, userId, type])
  @@index([workPlanId])
  @@index([userId])
}

model WorkPlanAuditLog {
  id          String   @id @default(cuid())
  workPlanId  String
  actorId     String?
  action      String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  workPlan WorkPlan @relation(fields: [workPlanId], references: [id], onDelete: Cascade)
  actor    User?    @relation("WorkPlanAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workPlanId])
  @@index([createdAt])
}

model OutstandingInvoice {
  id          String   @id @default(cuid())
  customerId  String
  number      String   @unique
  description String?
  amount      Decimal  @db.Decimal(15, 2)
  dueDate     DateTime
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model RolePermission {
  role        Role     @id
  permissions String[]
  updatedAt   DateTime @updatedAt
}

model ReminderSetting {
  key             String   @id
  enabled         Boolean  @default(false)
  config          Json?
  secretEncrypted String?
  updatedAt       DateTime @updatedAt
}

model ServiceContract {
  id        String                @id @default(cuid())
  customerId String
  number    String                @unique
  service   String
  startDate DateTime
  endDate   DateTime
  status    ServiceContractStatus @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  monthlyReports    MonthlyReport[]
  qcVisits          QcVisit[]
  vendorTreatments  VendorTreatment[]
}

model MonthlyReport {
  id         String          @id @default(cuid())
  contractId String
  reportDate DateTime
  status     WorkStatus      @default(PENDING)
  notes      String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  contract   ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model QcVisit {
  id          String          @id @default(cuid())
  contractId  String
  scheduledAt DateTime
  status      WorkStatus      @default(PENDING)
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  contract    ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model VendorTreatment {
  id          String          @id @default(cuid())
  contractId  String
  vendorName  String
  scheduledAt DateTime
  status      WorkStatus      @default(PENDING)
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  contract    ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Vendor {
  id                String       @id @default(cuid())
  code              String       @unique
  name              String
  vendorType        String       @default("Pest Control")
  serviceCategories String[]     @default([])
  picName           String?
  phone             String?
  email             String?
  address           String?      @db.Text
  coverageArea      String?
  npwpNumber        String?
  bankName          String?
  bankAccountName   String?
  bankAccountNo     String?
  rating            Int?
  status            VendorStatus @default(ACTIVE)
  notes             String?      @db.Text
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  orderSheets OrderSheet[]
  complaints  Complaint[]
}

model OrderSheet {
  id                  String           @id @default(cuid())
  number              String           @unique
  orderDate           DateTime         @default(now()) @db.Date
  status              OrderSheetStatus @default(DRAFT)
  createdByName       String?
  picInternal         String?
  agreementRef        String?
  quotationRef        String?
  customerId          String
  vendorId            String?
  customerSnapshot    Json             @default("{}")
  jobTitle            String
  serviceType         String?
  workMethod          String?
  priority            String?
  workDate            DateTime?        @db.Date
  workTime            String?
  estimatedDuration   String?
  technicianCount     String?
  specialInstruction  String?          @db.Text
  jobDescription      String?          @db.Text
  treatmentLocations  Json             @default("[]")
  materials           Json             @default("[]")
  vendorTechnicians   Json             @default("[]")
  costItems           Json             @default("[]")
  subtotal            Decimal?         @db.Decimal(15, 2)
  ppnPercent          Decimal?         @db.Decimal(5, 2)
  ppnAmount           Decimal?         @db.Decimal(15, 2)
  grandTotal          Decimal?         @db.Decimal(15, 2)
  terms               String[]         @default([])
  supportingDocuments Json             @default("[]")
  preparedByName      String?
  approvedByName      String?
  receivedByName      String?
  preparedAt          DateTime?
  approvedAt          DateTime?
  receivedAt          DateTime?
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  vendor   Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  complaints Complaint[]

  @@index([orderDate])
  @@index([status])
  @@index([customerId])
  @@index([vendorId])
}

model Complaint {
  id              String            @id @default(cuid())
  number          String            @unique
  complaintDate   DateTime          @default(now()) @db.Date
  customerId      String
  vendorId        String?
  orderSheetId    String?
  segmentType     String
  source          ComplaintSource   @default(CUSTOMER)
  internalTeam    String?
  complaintType   String
  priority        ComplaintPriority @default(NORMAL)
  status          ComplaintStatus   @default(OPEN)
  subject         String
  description     String            @db.Text
  location        String?
  reportedByName  String?
  reportedByPhone String?
  picInternal     String?
  dueDate         DateTime?         @db.Date
  rootCause       String?           @db.Text
  correctiveAction String?          @db.Text
  resolutionNotes String?           @db.Text
  resolvedAt      DateTime?
  closedAt        DateTime?
  followUps       Json              @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendor     Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  orderSheet OrderSheet? @relation(fields: [orderSheetId], references: [id], onDelete: SetNull)

  @@index([complaintDate])
  @@index([customerId])
  @@index([vendorId])
  @@index([orderSheetId])
  @@index([segmentType])
  @@index([status])
  @@index([source])
}

model PestMonthlyReport {
  id        String   @id @default(cuid())
  inquiryId String
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  bulan     Int
  tahun     Int
  segment   String
  pagesData Json?
  rekData   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inquiryId])
  @@index([segment])
  @@index([tahun, bulan])
}

model AgreementReport {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bulan      Int
  tahun      Int
  pagesData  Json?
  rekData    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
  @@index([tahun, bulan])
}

model Agreement {
  id                  String          @id @default(cuid())
  number              String          @unique
  tanggal             DateTime        @default(now())
  customerId          String
  quotationId         String?
  jenisLayanan        String          @default("Pest Control")
  lokasiPekerjaan     String          @default("") @db.Text
  areaPekerjaan       String?         @db.Text
  tanggalMulai        DateTime
  tanggalBerakhir     DateTime
  durasiKontrak       Int?
  serviceSchedule     Json            @default("[]")
  nilaiKontrak        Decimal         @db.Decimal(15, 2)
  ppn                 Decimal?        @db.Decimal(15, 2)
  grandTotal          Decimal?        @db.Decimal(15, 2)
  metodePembayaran    String?
  terminPembayaran    Json            @default("[]")
  rekening            String?
  garansi             String?
  status              AgreementStatus @default(DRAFT)
  picFumakillaNama    String?
  picFumakillaJabatan String?
  picFumakillaKontak  String?
  picKlienNama        String?
  picKlienJabatan     String?
  picKlienKontak      String?
  ttdFumakillaNama    String?
  ttdFumakillaJabatan String?
  ttdFumakillaTanggal DateTime?
  ttdKlienNama        String?
  ttdKlienJabatan     String?
  ttdKlienTanggal     DateTime?
  notes               String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotation Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@index([tanggalBerakhir])
}
