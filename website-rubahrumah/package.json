{
  "name": "rubahrumah-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web-rubahrumah",
    "build": "npm run build --workspace=apps/web-rubahrumah",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "npm run --workspace=packages/prisma db:generate",
    "db:migrate": "npm run --workspace=packages/prisma db:migrate",
    "db:push": "npm run --workspace=packages/prisma db:push",
    "db:studio": "npm run --workspace=packages/prisma db:studio",
    "db:seed": "npm run --workspace=packages/prisma db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
